# Google Maps
GOOGLE_MAPS_API_KEY=Tu_API_Key_de_Google_Maps

# Firebase – ruta al serviceAccountKey.json (local) o dejar vacío en GCP (usa ADC)
FIREBASE_CREDENTIALS_PATH=/ruta/a/tu/serviceAccountKey.json
FIREBASE_PROJECT_ID=tu-proyecto-firebase

# Restricción de IP: IPs separadas por coma que pueden invocar la función.
# Dejar vacío para permitir todas (útil en desarrollo local).
ALLOWED_CLIENT_IPS=127.0.0.1,::1,Tu_IP_Publica

# Parámetros del algoritmo genético
GA_POPULATION=180
GA_GENERATIONS=320
GA_MUTATION_RATE=0.15
GA_ELITE_RATE=0.1
GA_TOURNAMENT_SIZE=4
# GA_SEED=42  # descomentar para resultados reproducibles

# Velocidad media para estimar duración cuando la API no la devuelve
DEFAULT_SPEED_KMPH=35

# Orígenes permitidos para CORS (separados por coma)
CORS_ORIGINS=http://localhost:5173

# Ruta del caché SQLite (se sobreescribe automáticamente a /tmp en Cloud Functions)
# CACHE_DB_PATH=/tmp/cache.sqlite3
